# Backend API Configuration
# NOTE: In Chalice local mode, routes don't use the /api prefix
VITE_REACT_APP_BASE_URL=http://localhost:8000

# Cognito Configuration (LocalStack - will be updated after LocalStack starts)
VITE_COGNITO_URL=http://localhost:4566
VITE_COGNITO_CLIENT_ID=local_mock_client

# Skip B2C/Cognito redirect in local mode - use ezaudita login flow
VITE_SKIP_B2C=1

# Frontend Base URL
VITE_SG_BASE_URL=http://localhost:5173

# Application Version
VITE_REACT_APP_VERSION=3.0.0-local

# Sentry (Disabled for local development)
VITE_REACT_APP_SENTRY_DSN=

# Product IDs (Mock)
VITE_REACT_APP_PRODUCT_TRIAL=prod_mock_trial
VITE_REACT_APP_PRODUCT_ADD=prod_mock_add
VITE_REACT_APP_PRODUCT_HIGHVOLUME=prod_mock_highvolume
VITE_REACT_APP_PRODUCT_EXTRAUSERS=prod_mock_extrausers
VITE_REACT_APP_PRODUCT_DISPLAYS=prod_mock_displays

# AWS API Configuration (Mock)
VITE_REACT_APP_AWS_APID=mock_apid
VITE_REACT_APP_AWS_CPI=mock_cpi
VITE_REACT_APP_AWS_ENVI=local

# Seasonal Configuration
VITE_SEASONAL_DISCOUNT=0
